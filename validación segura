// Intentamos leer el número de forma segura
if (byte.TryParse(Console.ReadLine(), out opcionElegida))
{
    // Si el número es válido, comprobamos si existe en el Enum
    if (!Enum.IsDefined(typeof(nivelAlbañil), (nivelAlbañil)(opcionElegida - 1)))
    {
        Console.WriteLine("Ese número no corresponde a ningún nivel.");
    }    
}
else
{
    Console.WriteLine("Por favor, introduce solo números.");
}

// RECORRER ARRAY DE ENUM
// Obtenemos un array de strings con los nombres
string[] nombres = Enum.GetNames(typeof(nivelAlbañil));

Console.WriteLine("--- LISTA DE NIVELES ---");
for (int i = 0; i < nombres.Length; i++)
{
    // Usamos i + 1 para que el menú sea 1, 2, 3...
    Console.WriteLine($"{i + 1}. {nombres[i]}");
}
